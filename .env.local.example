# Supabase (required for smoke user seeding)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Playwright smoke targets
# TI app URL, e.g. http://127.0.0.1:3001
PLAYWRIGHT_BASE_URL=
# RI app URL, e.g. http://127.0.0.1:3000
PLAYWRIGHT_RI_BASE_URL=

# TI explicit site origin for email redirects
NEXT_PUBLIC_TI_SITE_URL=https://www.tournamentinsights.com

# TI smoke join test code
TI_SMOKE_JOIN_CODE=VALID

# TI smoke users
TI_SMOKE_SEED_ALLOW=false
TI_SMOKE_EXPLORER_EMAIL=explorer_test@example.com
TI_SMOKE_EXPLORER_PASSWORD=
TI_SMOKE_INSIDER_EMAIL=insider_test@example.com
TI_SMOKE_INSIDER_PASSWORD=
TI_SMOKE_WEEKENDPRO_EMAIL=weekendpro_test@example.com
TI_SMOKE_WEEKENDPRO_PASSWORD=

# Optional RI smoke override (defaults to TI insider creds)
RI_SMOKE_EMAIL=
RI_SMOKE_PASSWORD=
